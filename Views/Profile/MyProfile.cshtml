@model InsuranceManagement.Models.NhanVien
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Thông tin cá nhân";
    ViewData["ActiveMenu"] = "thongtin";
}

<div class="page-header">
    <h2>Thông tin cá nhân & Mức hưởng</h2>
    <p>Thông tin bảo hiểm và quyền lợi của bạn</p>
</div>

<div class="info-grid mb-4">
    <div class="info-card">
        <i class="fa-solid fa-id-badge info-card-icon"></i>
        <div class="info-card-label">Họ và tên</div>
        <div class="info-card-value">@Model.HoTen</div>
    </div>
    <div class="info-card">
        <i class="fa-solid fa-book info-card-icon"></i>
        <div class="info-card-label">Số sổ BHXH</div>
        <div class="info-card-value text-mono">@(Model.SoSoBHXH ?? "Chưa cập nhật")</div>
    </div>
    <div class="info-card">
        <i class="fa-solid fa-credit-card info-card-icon"></i>
        <div class="info-card-label">Số thẻ BHYT</div>
        <div class="info-card-value text-mono">@(Model.SoTheBHYT ?? "Chưa cập nhật")</div>
    </div>
    <div class="info-card">
        <i class="fa-solid fa-hospital info-card-icon"></i>
        <div class="info-card-label">Nơi đăng ký KCB ban đầu</div>
        <div class="info-card-value">@(Model.NoiDangKyKCB ?? "Chưa cập nhật")</div>
    </div>
    <div class="info-card">
        <i class="fa-solid fa-coins info-card-icon"></i>
        <div class="info-card-label">Lương đóng bảo hiểm</div>
        <div class="info-card-value text-mono">@Model.LuongDongBaoHiem.ToString("N0") <small style="font-size:12px;color:var(--gray-500)">VNĐ</small></div>
    </div>
</div>

<div class="grid-2">
    <div class="card">
        <div class="card-header">
            <h3><i class="fa-solid fa-percent" style="color:var(--primary)"></i> &nbsp;Tỷ lệ trích đóng áp dụng</h3>
        </div>
        <div class="card-body" style="padding:0">
            <table>
                <thead>
                    <tr><th>Loại bảo hiểm</th><th style="text-align:right">NV đóng</th><th style="text-align:right">Công ty đóng</th></tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="badge badge-blue">BHXH</span> Bảo hiểm xã hội</td>
                        <td style="text-align:right" class="text-mono">8.0%</td>
                        <td style="text-align:right" class="text-mono">17.5%</td>
                    </tr>
                    <tr>
                        <td><span class="badge badge-green">BHYT</span> Bảo hiểm y tế</td>
                        <td style="text-align:right" class="text-mono">1.5%</td>
                        <td style="text-align:right" class="text-mono">3.0%</td>
                    </tr>
                    <tr>
                        <td><span class="badge badge-yellow">BHTN</span> Bảo hiểm thất nghiệp</td>
                        <td style="text-align:right" class="text-mono">1.0%</td>
                        <td style="text-align:right" class="text-mono">1.0%</td>
                    </tr>
                    <tr>
                        <td><span class="badge badge-red">TNLĐ</span> Tai nạn lao động-BNN</td>
                        <td style="text-align:right" class="text-mono">0.0%</td>
                        <td style="text-align:right" class="text-mono">0.5%</td>
                    </tr>
                    <tr style="background:var(--gray-50);font-weight:700">
                        <td>Tổng cộng</td>
                        <td style="text-align:right;color:var(--danger)" class="text-mono">10.5%</td>
                        <td style="text-align:right;color:var(--success)" class="text-mono">22.0%</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div style="display:flex;flex-direction:column;gap:16px">
        <div class="card" style="flex:1">
            <div class="card-header">
                <h3><i class="fa-solid fa-star" style="color:var(--warning)"></i> &nbsp;Mức hưởng chính sách</h3>
            </div>
            <div class="card-body">
                <p style="font-size:14px;line-height:1.8;color:var(--gray-700);white-space:pre-line">
                    @(string.IsNullOrEmpty(Model.MucHuongChinhSach) ? "Chưa có thông tin. Vui lòng liên hệ phòng HR." : Model.MucHuongChinhSach)
                </p>
            </div>
        </div>
        <div class="card" style="flex:1">
            <div class="card-header">
                <h3><i class="fa-solid fa-heart" style="color:var(--danger)"></i> &nbsp;Người thụ hưởng</h3>
            </div>
            <div class="card-body">
                <p style="font-size:14px;line-height:1.8;color:var(--gray-700);white-space:pre-line">
                    @(string.IsNullOrEmpty(Model.NguoiThuHuong) ? "Chưa đăng ký người thụ hưởng." : Model.NguoiThuHuong)
                </p>
            </div>
        </div>
    </div>
</div>
