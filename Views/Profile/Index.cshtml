@model IEnumerable<InsuranceManagement.Models.NhanVien>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Quản lý hồ sơ nhân viên";
    ViewData["ActiveMenu"] = "nhanvien";
    var search = ViewData["Search"]?.ToString() ?? "";
}

<div class="page-header flex justify-between items-center">
    <div>
        <h2>Quản lý hồ sơ bảo hiểm</h2>
        <p>Xem, thêm mới và cập nhật thông tin bảo hiểm nhân viên</p>
    </div>
    <a href="/Profile/Create" class="btn btn-primary">
        <i class="fa-solid fa-user-plus"></i> Thêm nhân viên mới
    </a>
</div>

<div class="card mb-4">
    <div class="card-body" style="padding:14px 18px">
        <form method="get" asp-action="Index" style="display:flex;gap:10px">
            <div style="position:relative;flex:1;max-width:400px">
                <i class="fa-solid fa-magnifying-glass" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--gray-500);font-size:13px"></i>
                <input type="text" name="search" value="@search" placeholder="Tìm theo họ tên hoặc mã nhân viên..." style="padding-left:36px"/>
            </div>
            <button type="submit" class="btn btn-primary">Tìm kiếm</button>
            @if (!string.IsNullOrEmpty(search))
            {
                <a href="/Profile/Index" class="btn btn-outline"><i class="fa-solid fa-xmark"></i> Xóa lọc</a>
            }
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3><i class="fa-solid fa-users" style="color:var(--primary)"></i> &nbsp;Danh sách nhân viên
            <span style="background:var(--gray-100);color:var(--gray-600);font-size:12px;padding:2px 10px;border-radius:20px;margin-left:8px;font-weight:600">@Model.Count() người</span>
        </h3>
    </div>
    <div class="table-wrapper">
        @if (!Model.Any())
        {
            <div style="text-align:center;padding:56px 0;color:var(--gray-500)">
                <i class="fa-solid fa-users-slash" style="font-size:36px;margin-bottom:12px;display:block;opacity:.35"></i>
                Không tìm thấy nhân viên nào
            </div>
        }
        else
        {
            <table>
                <thead>
                    <tr><th>ID</th><th>Họ và tên</th><th>Số sổ BHXH</th><th>Số thẻ BHYT</th><th>Nơi KCB</th><th style="text-align:right">Lương đóng BH</th><th style="text-align:center">Thao tác</th></tr>
                </thead>
                <tbody>
                    @foreach (var nv in Model)
                    {
                        <tr>
                            <td class="text-mono" style="color:var(--gray-500)">NV@nv.NhanVienID.ToString("D4")</td>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px">
                                    <div style="width:32px;height:32px;border-radius:50%;background:var(--primary-light);color:var(--primary);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;flex-shrink:0">@nv.HoTen[0]</div>
                                    <span style="font-weight:600">@nv.HoTen</span>
                                </div>
                            </td>
                            <td class="text-mono">@(nv.SoSoBHXH ?? "—")</td>
                            <td class="text-mono">@(nv.SoTheBHYT ?? "—")</td>
                            <td style="max-width:180px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@(nv.NoiDangKyKCB ?? "—")</td>
                            <td style="text-align:right;font-weight:700" class="text-mono">@nv.LuongDongBaoHiem.ToString("N0") ₫</td>
                            <td style="text-align:center">
                                <div style="display:flex;gap:6px;justify-content:center">
                                    <a href="/Profile/Details/@nv.NhanVienID" class="btn btn-outline btn-sm">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                    <a href="/Profile/Edit/@nv.NhanVienID" class="btn btn-warning btn-sm">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>
                                    <button class="btn btn-danger btn-sm" onclick="confirmDelete(@nv.NhanVienID, '@nv.HoTen')">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- Modal xác nhận xóa -->
<div class="modal-overlay" id="modal-xoa">
    <div class="modal" style="max-width:420px">
        <div class="modal-title"><i class="fa-solid fa-triangle-exclamation" style="color:var(--danger)"></i> Xác nhận xóa nhân viên</div>
        <p style="color:var(--gray-700);font-size:14px;line-height:1.7">
            Bạn có chắc muốn xóa nhân viên <strong id="del-name"></strong>?<br/>
            Tất cả dữ liệu lịch sử đóng tiền và claim sẽ bị xóa theo.
        </p>
        <div class="modal-footer">
            <button class="btn btn-outline" onclick="closeModal('modal-xoa')">Hủy</button>
            <form id="form-xoa" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger"><i class="fa-solid fa-trash"></i> Xóa</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function confirmDelete(id, name) {
        document.getElementById('del-name').textContent = name;
        document.getElementById('form-xoa').action = '/Profile/Delete/' + id;
        openModal('modal-xoa');
    }
</script>
}
