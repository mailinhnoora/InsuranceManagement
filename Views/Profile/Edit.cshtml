@model InsuranceManagement.Models.NhanVien
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Cập nhật hồ sơ";
    ViewData["ActiveMenu"] = "nhanvien";
}
<div class="page-header">
    <h2>Cập nhật hồ sơ bảo hiểm</h2>
    <p>@Model.HoTen – NV@Model.NhanVienID.ToString("D4")</p>
</div>

<div class="card" style="max-width:680px">
    <div class="card-body">
        <form method="post" asp-action="Edit">
            @Html.AntiForgeryToken()
            <input type="hidden" name="NhanVienID" value="@Model.NhanVienID" />
            <input type="hidden" name="TaiKhoanID" value="@Model.TaiKhoanID" />
            <div class="grid-2">
                <div class="form-group" style="grid-column:1/-1">
                    <label>Họ và tên <span style="color:var(--danger)">*</span></label>
                    <input type="text" name="HoTen" value="@Model.HoTen" required />
                </div>
                <div class="form-group">
                    <label>Số sổ BHXH</label>
                    <input type="text" name="SoSoBHXH" value="@Model.SoSoBHXH" />
                </div>
                <div class="form-group">
                    <label>Số thẻ BHYT</label>
                    <input type="text" name="SoTheBHYT" value="@Model.SoTheBHYT" />
                </div>
                <div class="form-group" style="grid-column:1/-1">
                    <label>Nơi đăng ký KCB ban đầu</label>
                    <input type="text" name="NoiDangKyKCB" value="@Model.NoiDangKyKCB" />
                </div>
                <div class="form-group">
                    <label>Lương đóng bảo hiểm (VNĐ) <span style="color:var(--danger)">*</span></label>
                    <input type="number" name="LuongDongBaoHiem" value="@Model.LuongDongBaoHiem" min="0" required />
                </div>
            </div>
            <div class="form-group">
                <label>Mức hưởng chính sách</label>
                <textarea name="MucHuongChinhSach" rows="2">@Model.MucHuongChinhSach</textarea>
            </div>
            <div class="form-group">
                <label>Người thụ hưởng</label>
                <textarea name="NguoiThuHuong" rows="2">@Model.NguoiThuHuong</textarea>
            </div>
            <div style="display:flex;gap:10px;justify-content:flex-end">
                <a href="/Profile/Index" class="btn btn-outline">Hủy</a>
                <button type="submit" class="btn btn-warning"><i class="fa-solid fa-floppy-disk"></i> Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>
