@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Không có quyền truy cập";
}
<div style="text-align:center;padding:80px 0">
    <i class="fa-solid fa-lock" style="font-size:56px;color:var(--danger);opacity:.7;margin-bottom:20px;display:block"></i>
    <h2 style="font-size:24px;font-weight:800;margin-bottom:10px">Không có quyền truy cập</h2>
